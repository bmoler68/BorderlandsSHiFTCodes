# Secrets configuration file template for Borderlands SHiFT Codes
# Copy this file to secrets.properties and fill in your actual values
# The secrets.properties file is gitignored and will not be committed

# Supabase (borderlands_shift.shift_codes_current — same as dashboard)
supabaseUrl=https://YOUR_PROJECT.supabase.co
supabaseAnonKey=YOUR_SUPABASE_ANON_KEY_HERE

# App URLs
# Note: shift.website.url is hardcoded in AppConfig.kt and does not need to be here
privacy.policy.url=YOUR_PRIVACY_POLICY_URL_HERE
about.page.url=YOUR_ABOUT_PAGE_URL_HERE

